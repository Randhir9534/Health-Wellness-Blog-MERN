<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Subscriber List</title>
    <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="/stylesheet/css/sb-admin-2.min.css" rel="stylesheet">
</head>

<body id="page-top">

    <div id="wrapper">

        <!-- Sidebar -->
        <%- include("layout/sidebar.ejs") %>
        <!-- End of Sidebar -->

        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                <%- include('layout/topbar.ejs') %>

                <div class="container-fluid">
                    <h1 class="h3 mb-4 text-gray-800 text-center">Newsletter Subscribers</h1>

                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>Email</th>
                                <th>Subscribed On</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% subscribers.forEach((subscriber,idx) => { %>
                                <tr>
                                    <td><%= idx+1 %></td>
                                    <td><%= subscriber.email %></td>
                                    <td><%= new Date(subscriber.subscribedOn).toLocaleDateString() %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>

                </div>
            </div>

            <%- include('layout/footer') %>
        </div>
    </div>

    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="/js/sb-admin-2.min.js"></script>
</body>

</html>
